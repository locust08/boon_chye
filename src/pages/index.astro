---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import ServiceList from "../components/ServiceList.astro";
import { brand, faqs, projectImages, services, testimonials, trustPoints } from "../data/site";

const whatsappHref = `https://wa.me/${brand.phone.replace(/\D/g, "")}`;
---
<BaseLayout
  title="Boon Chye Contractor Services"
  description="Boon Chye contractor services for roof leaking, waterproofing, plumbing, electrical, renovation, sewerage and drainage work in KL and Selangor."
>
  <section class="hero-section home">
    <img alt="Sky background" class="sky-bg" loading="lazy" src="/images/Sky.svg" />
    <div class="w-layout-blockcontainer container-large padding w-container">
      <div class="w-layout-blockcontainer container w-container">
        <div class="hero-content-wrapper" data-w-id="610939f4-60e3-968d-4b41-565332ab7711">
          <div class="hero-content-left">
            <div class="hero-top-content" data-w-id="4cdf8785-4f09-71ec-c480-bb8d669951b1" style="opacity:1">
              <p class="hero-label">one-stop contractor in KL & Selangor</p>
              <div class="title-wrapper">
                <h1 class="display-heading-01">Boon Chye Contractor Services</h1>
                <p class="hero-subtitle home">Reliable repairs and renovation support for homes and businesses across KL and Selangor, from roof leaks and waterproofing to plumbing, electrical, drainage and general works.</p>
              </div>
            </div>
            <div class="hero-bottom-content" data-w-id="941497c9-4a24-2891-d5d5-ca61040f5106" style="opacity:1">
              <div class="hero-button-wrapper">
                <a class="button-style-01 w-button" href="/contact">Get a free quote</a>
                <a class="button-style-02 w-button" href="/service">Explore services</a>
              </div>
              <div class="call-wrapper whatsapp-contact">
                <div class="call-title-wrapper">
                  <img alt="Call icon" class="call-icon" loading="lazy" src="/images/phone-call-1.svg" />
                  <p class="call-title">Call / WhatsApp</p>
                </div>
                <a class="link-block w-inline-block" href={whatsappHref} target="_blank" rel="noopener">
                  <h3 class="link-text">{brand.phone}</h3>
                </a>
              </div>
            </div>
          </div>
          <div class="hero-right-content" data-w-id="5c69c059-55ad-2ec6-0e08-0dc5e7c15336" style="opacity:1">
            <img alt="Verified service mark" class="verified-logo" loading="lazy" src="/images/Group-3.svg" />
            <div class="varified-title-wrapper">
              <h4>20+</h4>
              <p class="verified-subtitle">Years of hands-on repair and renovation experience across KL and Selangor.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
    <img alt="Boon Chye roofing and waterproofing service" class="hero-image" loading="eager" sizes="(max-width: 2880px) 100vw, 2880px" src="/images/red-roof-2-2.png" srcset="/images/red-roof-2-2-p-500.png 500w, /images/red-roof-2-2-p-800.png 800w, /images/red-roof-2-2-p-1080.png 1080w, /images/red-roof-2-2-p-1600.png 1600w, /images/red-roof-2-2-p-2000.png 2000w, /images/red-roof-2-2.png 2880w" style="opacity:1" />
  </section>

  <section class="ticker">
    <div class="ticker-wrapper">
      {services.map((service) => (
        <div class="single-ticker-content">
          <div class="ticker-icon-box"><div class="ticker-icon-wrapper"><img alt="Service icon" class="ticker-icon" loading="lazy" src="/images/Group-4.svg" /></div></div>
          <p class="ticker-title">{service.title}</p>
        </div>
      ))}
    </div>
    <div class="ticker-wrapper">
      {services.map((service) => (
        <div class="single-ticker-content">
          <div class="ticker-icon-box"><div class="ticker-icon-wrapper"><img alt="Roofing service icon" class="ticker-icon" loading="lazy" src="/images/roofing-1.svg" /></div></div>
          <p class="ticker-title">{service.title}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="about-section padding">
    <div class="w-layout-blockcontainer container-large about section-padding w-container">
      <div class="w-layout-blockcontainer container w-container">
        <div class="about-content-wrapper">
          <img alt="Roof and property repair work" class="about-image" loading="lazy" sizes="(max-width: 767px) 100vw, (max-width: 991px) 727.984375px, 939.984375px" src="/images/red-roof-with-clouds.png" srcset="/images/red-roof-with-clouds-p-500.png 500w, /images/red-roof-with-clouds-p-800.png 800w, /images/red-roof-with-clouds-p-1080.png 1080w, /images/red-roof-with-clouds.png 1380w" style="opacity:1" />
          <div class="about-content">
            <div class="title-wrapper" style="opacity:1">
              <h2 class="section-title">One contractor team <span class="highlight-title">for property repairs.</span></h2>
              <p class="section-subtitle about">From urgent leaks to planned renovation work, Boon Chye helps property owners coordinate the right trade team, inspect the issue clearly and complete repairs with practical, transparent recommendations.</p>
            </div>
            <div class="about-icon-box-wrapper" style="opacity:1">
              <div class="single-about-icon-box">
                <img alt="Tool icon" class="about-icon" loading="lazy" src="/images/Circular-Saw-Tool-1.png" />
                <div class="about-icon-box-title-wrapper">
                  <h4>Free Inspection</h4>
                  <p>Share your issue and location so the team can assess the right repair path before quotation.</p>
                </div>
              </div>
              <div class="single-about-icon-box">
                <img alt="Construction icon" class="about-icon" loading="lazy" src="/images/Construction-Helmet-Tool.png" />
                <div class="about-icon-box-title-wrapper">
                  <h4>No Hidden Costs</h4>
                  <p>Clear scope, practical recommendations and transparent pricing before work begins.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="service-section section-padding">
    <div class="w-layout-blockcontainer container w-container">
      <div class="section-content-wrapper">
        <div class="section-header" style="opacity:1">
          <div class="title-wrapper style-02">
            <h2 class="section-title">Our Services</h2>
            <p class="section-subtitle">Get help for common property issues through one experienced team, including roof leaks, waterproofing, plumbing, electrical, renovation, sewerage and drainage work.</p>
          </div>
          <div><a class="button-style-03 w-button" href="/service">View all</a></div>
        </div>
        <ServiceList />
      </div>
    </div>
  </section>

  <section class="why-choose-us section-padding">
    <div class="w-layout-blockcontainer container w-container">
      <div class="section-content-wrapper">
        <div class="title-wrapper style-02" style="opacity:1">
          <h2 class="section-title">Why Choose Boon Chye?</h2>
          <p class="section-subtitle">Property owners choose Boon Chye for practical advice, clear quotations and dependable repair support across multiple trades.</p>
        </div>
        <div class="why-choose-card-wrapper" style="opacity:1">
          {trustPoints.map((point) => (
            <div class="single-choose-us-card">
              <h4 class="choose-us-card-title">{point.title}</h4>
              <p class="choose-us-card-subtitle">{point.text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="project-gallery-section padding">
    <div class="w-layout-blockcontainer container w-container">
      <div class="section-content-wrapper">
        <div class="title-wrapper style-02" style="opacity:1">
          <h2 class="section-title">Project Gallery</h2>
          <p class="section-subtitle">View examples of roof repair, waterproofing, renovation and property maintenance work completed for homes and commercial sites.</p>
        </div>
        <div class="project-gallery w-slider" data-animation="slide" data-autoplay="false" data-duration="500" data-hide-arrows="false" data-infinite="true" style="opacity:1">
          <div class="project-gallery-mask w-slider-mask">
            {projectImages.map((image) => (
              <div class="w-slide">
                <div class="project-gallery-image-wrapper">
                  <img alt={image.alt} class="project-gallery-image" loading="lazy" sizes="(max-width: 767px) 100vw, (max-width: 991px) 728px, 940px" src={image.src} srcset={image.set} />
                </div>
              </div>
            ))}
          </div>
          <div class="testimonial-slider-nav w-slider-nav w-slider-nav-invert w-round"></div>
        </div>
        <div class="metrics" style="opacity:1">
          <div class="single-metrics"><h2 class="metrics-title js-count" data-count-target="20" data-count-suffix="+">20+</h2><p class="metrics-subtitle">years of hands-on experience</p></div>
          <div class="single-metrics"><h2 class="metrics-title js-count" data-count-target="24" data-count-suffix="/7">24/7</h2><p class="metrics-subtitle">WhatsApp support for urgent enquiries</p></div>
          <div class="single-metrics"><h2 class="metrics-title js-count" data-count-target="5">5</h2><p class="metrics-subtitle">core service categories</p></div>
          <div class="single-metrics last"><h2 class="metrics-title">KL</h2><p class="metrics-subtitle">and Selangor service coverage</p></div>
        </div>
      </div>
    </div>
  </section>

  <section class="how-it-works-section padding">
    <div class="w-layout-blockcontainer container-large how-it-works section-padding w-container">
      <div class="w-layout-blockcontainer container w-container">
        <div class="section-content-wrapper">
          <div class="title-wrapper style-02" style="opacity:1">
            <h2 class="section-title">How Boon Chye Works</h2>
            <p class="section-subtitle">A practical service flow based on Boon Chye's roofing, waterproofing, plumbing, electrical, renovation and sewerage support across KL and Selangor.</p>
          </div>
          <div class="how-it-works-content-wrapper" style="opacity:1">
            <div class="how-it-works-content-left">
              <div class="single-process"><div class="point-wrapper"><div class="circle-point"><img alt="Process step icon" class="point-icon" loading="lazy" src="/images/Group-1597884498-1.svg" /></div></div><div class="process-title-wrapper"><h4 class="process-title">Call or WhatsApp</h4><p class="process-subtitle">Send your photos, location and service needed, whether it is roof leaking, waterproofing, plumbing, electrical, renovation or sewerage work.</p></div></div>
              <div class="single-process"><div class="point-wrapper"><div class="circle-point"><img alt="Process step icon" class="point-icon" loading="lazy" src="/images/Group-1597884498-1.svg" /></div></div><div class="process-title-wrapper"><h4 class="process-title">Inspection & Quotation</h4><p class="process-subtitle">The team checks the site condition, explains the recommended repair method and provides a clear quotation before work begins.</p></div></div>
              <div class="single-process"><div class="point-wrapper"><div class="circle-point"><img alt="Process step icon" class="point-icon" loading="lazy" src="/images/Group-1597884498-1.svg" /></div></div><div class="process-title-wrapper"><h4 class="process-title">Repair & Follow-Up</h4><p class="process-subtitle">The relevant trade team completes the work, from leak repair to renovation or drainage service, with after-sales support where applicable.</p></div></div>
              <div class="border-line"></div>
            </div>
            <div class="process-image-wrapper">
              <img alt="Boon Chye site inspection process" class="process-image" loading="lazy" sizes="100vw" src="/images/male-builder-doing-thermal-insulation-roof-wooden-frame-house-by-polyurethane-foam.png" srcset="/images/male-builder-doing-thermal-insulation-roof-wooden-frame-house-by-polyurethane-foam-p-500.png 500w, /images/male-builder-doing-thermal-insulation-roof-wooden-frame-house-by-polyurethane-foam-p-800.png 800w, /images/male-builder-doing-thermal-insulation-roof-wooden-frame-house-by-polyurethane-foam-p-1080.png 1080w, /images/male-builder-doing-thermal-insulation-roof-wooden-frame-house-by-polyurethane-foam.png 1100w" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="testimonial-section padding-bottom">
    <div class="w-layout-blockcontainer container w-container">
      <div class="section-content-wrapper">
        <div class="section-header" style="opacity:1">
          <div class="title-wrapper style-02"><h2 class="section-title">What Clients Say</h2><p class="section-subtitle">Hear from customers who trusted Boon Chye for roof leak repairs, waterproofing, plumbing, renovation and drainage work.</p></div>
          <div><a class="button-style-03 w-button" href="/contact">Contact us</a></div>
        </div>
        <div class="testimonial-slider w-slider" data-animation="slide" data-autoplay="false" data-duration="500" data-hide-arrows="false" data-infinite="true" style="opacity:1">
          <div class="testimonial-slider-mask w-slider-mask">
            {testimonials.map((item) => (
              <div class="w-slide">
                <div class="single-testimonial">
                  <div class="rating-icon-wrapper"><img alt="Star" loading="lazy" src="/images/star-1-3.svg" /><img alt="Star" loading="lazy" src="/images/star-1-3.svg" /><img alt="Star" loading="lazy" src="/images/star-1-3.svg" /><img alt="Star" loading="lazy" src="/images/star-1-3.svg" /><img alt="Star" loading="lazy" src="/images/star-1-3.svg" /></div>
                  <div class="testimonial-content-wrapper"><p class="testimonial-title">{item.title}</p><p class="testimonial-content">"{item.quote}"</p></div>
                  <div class="testimonial-author">
                    <img alt={`${item.name} testimonial`} class="testimonial-author-image" loading="lazy" src={item.avatar} />
                    <div class="testimonial-author-details"><p class="testimonial-author-name">{item.name}</p><p class="testimonial-author-designation">{item.role}</p></div>
                  </div>
                </div>
              </div>
            ))}
          </div>
          <div class="testimonial-slider-nav w-slider-nav w-slider-nav-invert w-round"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="faq-section padding-bottom">
    <div class="w-layout-blockcontainer container w-container">
      <div class="faq-content-wrapper">
        <div class="faq-content-left">
          <div class="title-wrapper testimonial"><h2 class="section-title">Frequently Asked Questions</h2><p class="section-subtitle style-03">Quick answers before you book an inspection, request a quotation or arrange repair work.</p></div>
          <div class="faq-bottom-content"><div class="faq-bottom-title-wrapper"><p class="faq-contact-title">Need help with your property?</p><p>Contact Boon Chye with your photos, location and service needed.</p></div><a class="button-style-01 w-button" href="/contact">Contact us</a></div>
        </div>
        <div class="faq-s">
          {faqs.map((faq) => (
            <div class="single-faq w-dropdown" data-delay="0" data-hover="false">
              <div class="question w-dropdown-toggle"><div class="question-content-wrapper"><h4 class="question-title">{faq.question}</h4><img alt="Open answer" class="faq-icon" loading="lazy" src="/images/arrow-down.svg" /></div></div>
              <nav class="answer w-dropdown-list"><div class="answer-content-wrapper"><p class="answer-content">{faq.answer}</p></div></nav>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
