---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import HeroSimple from "../components/HeroSimple.astro";
import { services } from "../data/site";

const galleryCategories = [
  { key: "roof-waterproofing", title: "Roof Leaking / Waterproofing", text: "Roof leak, ceiling leak, membrane and PU injection." },
  { key: "plumbing-water-pump", title: "Plumbing / Water Pump", text: "Leaks, pipe repair, water tank and pump." },
  { key: "electrical", title: "Electrical", text: "Wiring, lighting, plug point and fuse box." },
  { key: "renovation", title: "Renovation", text: "Kitchen, bathroom and extension works." },
  { key: "sewerage-drainage", title: "Sewerage / Drainage", text: "Blockage, grease trap, jetting and CCTV inspection." },
];

const projectGroups = [
  {
    filter: "roof-waterproofing",
    category: "Roof Leaking / Waterproofing",
    titles: [
      "Roof Leak Inspection",
      "Flat Roof Membrane Work",
      "Ceiling Leak Repair Area",
      "Roof Flashing Sealant Work",
      "Completed Waterproofing Finish",
    ],
  },
  {
    filter: "plumbing-water-pump",
    category: "Plumbing / Water Pump",
    titles: [
      "Sink Pipe Leak Repair",
      "Water Pump Installation",
      "Tap and Pipe Replacement",
      "Rooftop Tank Piping Check",
      "Completed Pump Setup",
    ],
  },
  {
    filter: "electrical",
    category: "Electrical",
    titles: [
      "Distribution Board Check",
      "Plug Point Replacement",
      "Ceiling Light Installation",
      "Surface Conduit Wiring",
      "Completed Lighting Setup",
    ],
  },
  {
    filter: "renovation",
    category: "Renovation",
    titles: [
      "Bathroom Tile Preparation",
      "Kitchen Renovation Works",
      "Plaster Ceiling Repair",
      "Room Extension Framing",
      "Completed Interior Renovation",
    ],
  },
  {
    filter: "sewerage-drainage",
    category: "Sewerage / Drainage",
    titles: [
      "Outdoor Drain Inspection",
      "Drain Jetting Service",
      "Grease Trap Cleaning",
      "CCTV Drain Inspection",
      "Completed Drainage Cleanup",
    ],
  },
];

const featuredProjects = projectGroups.flatMap((group) =>
  group.titles.map((title, index) => {
    const number = String(index + 1).padStart(2, "0");
    const image = `/images/gallery/generated/${group.filter}-${number}.webp`;
    return {
      filter: group.filter,
      category: group.category,
      title,
      source: "Boon Chye portfolio example",
      image,
      imageSet: `${image} 1200w`,
      alt: `${title} example for ${group.category}`,
    };
  })
);

const workflowGroups = [
  {
    key: "roof-waterproofing",
    title: "Roof / Waterproofing",
    steps: [
      { title: "Leak Area Inspection", text: "Roof tile or ceiling leak area checked before repair work.", image: "/images/gallery/generated/roof-waterproofing-01.webp", alt: "Roof leak inspection before repair" },
      { title: "Waterproofing Work", text: "Membrane, sealant or waterproofing treatment applied on site.", image: "/images/gallery/generated/roof-waterproofing-02.webp", alt: "Flat roof waterproofing work in progress" },
      { title: "Finished Surface", text: "Clean roof surface after waterproofing or leak repair.", image: "/images/gallery/generated/roof-waterproofing-05.webp", alt: "Completed roof waterproofing surface" },
    ],
  },
  {
    key: "plumbing-water-pump",
    title: "Plumbing / Pump",
    steps: [
      { title: "Pipe Leak Check", text: "Pipe, tap or tank connection inspected before repair.", image: "/images/gallery/generated/plumbing-water-pump-01.webp", alt: "Sink pipe leak repair inspection" },
      { title: "Tank Piping Work", text: "Technician checks piping, pump or water tank connection.", image: "/images/gallery/generated/plumbing-water-pump-04.webp", alt: "Rooftop tank piping work in progress" },
      { title: "Completed Pump Setup", text: "Pump and pipe installation cleaned up for handover.", image: "/images/gallery/generated/plumbing-water-pump-05.webp", alt: "Completed water pump and pipe installation" },
    ],
  },
  {
    key: "electrical",
    title: "Electrical",
    steps: [
      { title: "Electrical Check", text: "Distribution board, plug point or lighting issue inspected.", image: "/images/gallery/generated/electrical-01.webp", alt: "Distribution board electrical inspection" },
      { title: "Installation Work", text: "Lighting, wiring or plug point work completed safely.", image: "/images/gallery/generated/electrical-03.webp", alt: "Ceiling light installation in progress" },
      { title: "Finished Setup", text: "Switches, lights and fittings are tidied after testing.", image: "/images/gallery/generated/electrical-05.webp", alt: "Completed electrical lighting setup" },
    ],
  },
  {
    key: "renovation",
    title: "Renovation",
    steps: [
      { title: "Area Preparation", text: "Bathroom, kitchen or ceiling area prepared before renovation.", image: "/images/gallery/generated/renovation-01.webp", alt: "Bathroom renovation area before work" },
      { title: "Build In Progress", text: "Partition, ceiling, tiling or fitting works carried out.", image: "/images/gallery/generated/renovation-04.webp", alt: "Room extension framing work in progress" },
      { title: "Completed Interior", text: "Renovated area cleaned and ready for use.", image: "/images/gallery/generated/renovation-05.webp", alt: "Completed interior renovation result" },
    ],
  },
  {
    key: "sewerage-drainage",
    title: "Sewerage / Drainage",
    steps: [
      { title: "Drain Inspection", text: "Blocked drain, grease trap or pipe access checked first.", image: "/images/gallery/generated/sewerage-drainage-01.webp", alt: "Outdoor drain blockage inspection" },
      { title: "Clearing Work", text: "Jetting, CCTV inspection or cleaning work carried out.", image: "/images/gallery/generated/sewerage-drainage-02.webp", alt: "Drain jetting service work in progress" },
      { title: "Cleaned Drainage", text: "Drainage area cleaned after service and inspection.", image: "/images/gallery/generated/sewerage-drainage-05.webp", alt: "Completed drainage cleanup result" },
    ],
  },
];

---
<BaseLayout
  title="Gallery"
  description="View Boon Chye project and service visuals for roofing, waterproofing, renovation, plumbing, electrical, sewerage and drainage work."
  path="/gallery"
>
  <HeroSimple label="gallery / portfolio" title="Our Project Portfolio" subtitle="Browse Boon Chye work examples across roofing, waterproofing, renovation, plumbing, electrical, sewerage and drainage services." />

  <section class="gallery-portfolio-section section-padding">
    <div class="w-layout-blockcontainer container w-container">
      <div class="section-content-wrapper">
        <div class="title-wrapper style-02" style="opacity:1">
          <h2 class="section-title">Browse Work by Service</h2>
          <p class="section-subtitle">Select a service category to view related project examples.</p>
        </div>
        <div class="gallery-category-grid" data-gallery-filters style="opacity:1">
          {galleryCategories.map((category, index) => (
            <button class="gallery-category-card" type="button" data-gallery-filter={category.key} aria-pressed="false">
              <div class="gallery-category-icon">
                <img alt="" aria-hidden="true" loading="lazy" src={category.image ?? services.find((service) => service.slug === category.key || (category.key === "roof-waterproofing" && service.slug === "roof-leaking-waterproofing"))?.hoverImage} />
              </div>
              <div class="gallery-category-content">
                <p class="gallery-category-title">{category.title}</p>
                <p class="gallery-category-text">{category.text}</p>
              </div>
            </button>
          ))}
        </div>
        <div class="gallery-featured-grid" style="opacity:1">
          {featuredProjects.map((project) => (
            <article class="gallery-project-card" data-gallery-project={project.filter}>
              <div class="gallery-project-image-wrapper">
                <img alt={project.alt} class="gallery-project-image" loading="lazy" sizes="(max-width: 767px) 100vw, (max-width: 991px) 50vw, 33vw" src={project.image} srcset={project.imageSet} />
              </div>
              <div class="gallery-project-content">
                <p class="gallery-project-category">{project.category}</p>
                <h3 class="gallery-project-title">{project.title}</h3>
                <p class="gallery-project-source">{project.source}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="gallery-workflow-section section-padding">
    <div class="w-layout-blockcontainer container w-container">
      <div class="section-content-wrapper">
        <div class="title-wrapper style-02" style="opacity:1">
          <h2 class="section-title">Project Progress Examples</h2>
          <p class="section-subtitle">See how photos can show the issue, repair process and completed result.</p>
        </div>
        <div class="gallery-workflow-tabs" data-workflow-filters style="opacity:1">
          {workflowGroups.map((group) => (
            <button class="gallery-workflow-tab" type="button" data-workflow-filter={group.key} aria-pressed="false">{group.title}</button>
          ))}
        </div>
        <div class="gallery-workflow-panels" style="opacity:1">
          {workflowGroups.map((group) => (
            <div class="gallery-workflow-panel" data-workflow-panel={group.key}>
              <div class="gallery-workflow-grid">
                {group.steps.map((step, index) => (
                  <article class="gallery-workflow-card">
                    <div class="gallery-workflow-image-wrapper">
                      <img alt={step.alt} class="gallery-workflow-image" loading="lazy" src={step.image} />
                    </div>
                    <div class="gallery-workflow-content">
                      <p class="gallery-workflow-number">{String(index + 1).padStart(2, "0")}</p>
                      <h3>{step.title}</h3>
                      <p>{step.text}</p>
                    </div>
                  </article>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const galleryFilters = [...document.querySelectorAll("[data-gallery-filter]")];
      const projects = [...document.querySelectorAll("[data-gallery-project]")];
      const workflowFilters = [...document.querySelectorAll("[data-workflow-filter]")];
      const workflowPanels = [...document.querySelectorAll("[data-workflow-panel]")];
      if (!galleryFilters.length || !projects.length || !workflowFilters.length || !workflowPanels.length) return;

      const setServiceFilter = (filter) => {
        galleryFilters.forEach((button) => {
          const active = button.getAttribute("data-gallery-filter") === filter;
          button.classList.toggle("is-active", active);
          button.setAttribute("aria-pressed", String(active));
        });

        workflowFilters.forEach((button) => {
          const active = button.getAttribute("data-workflow-filter") === filter;
          button.classList.toggle("is-active", active);
          button.setAttribute("aria-pressed", String(active));
        });

        projects.forEach((project) => {
          project.hidden = project.getAttribute("data-gallery-project") !== filter;
        });

        workflowPanels.forEach((panel) => {
          panel.hidden = panel.getAttribute("data-workflow-panel") !== filter;
        });
      };

      galleryFilters.forEach((button) => {
        button.addEventListener("click", () => {
          const filter = button.getAttribute("data-gallery-filter");
          if (filter) setServiceFilter(filter);
        });
      });

      workflowFilters.forEach((button) => {
        button.addEventListener("click", () => {
          const filter = button.getAttribute("data-workflow-filter");
          if (filter) setServiceFilter(filter);
        });
      });

      setServiceFilter("roof-waterproofing");
    })();
  </script>

  <CTA title="Have a similar project?" text="Send photos of the roof, leak area, plumbing fault, wiring area, renovation space or drainage issue for a clearer first response." />
</BaseLayout>
