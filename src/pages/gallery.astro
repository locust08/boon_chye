---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import HeroSimple from "../components/HeroSimple.astro";
import { projectImages, services } from "../data/site";
---
<BaseLayout
  title="Gallery"
  description="View Boon Chye project and service visuals for roofing, waterproofing, renovation, plumbing, electrical, sewerage and drainage work."
  path="/gallery"
>
  <HeroSimple label="gallery / projects" title="Project Gallery" subtitle="A consolidated gallery using the template's existing project image slots for Boon Chye's major service families." />

  <section class="project-gallery-section padding">
    <div class="w-layout-blockcontainer container w-container">
      <div class="section-content-wrapper">
        <div class="title-wrapper style-02" style="opacity:1">
          <h2 class="section-title">Work Categories</h2>
          <p class="section-subtitle">Gallery labels align with the deduped service map from the source websites.</p>
        </div>
        <div class="project-gallery w-slider" data-animation="slide" data-autoplay="false" data-duration="500" data-hide-arrows="false" data-infinite="true" style="opacity:1">
          <div class="project-gallery-mask w-slider-mask">
            {projectImages.map((image) => (
              <div class="w-slide">
                <div class="project-gallery-image-wrapper">
                  <img alt={image.alt} class="project-gallery-image" loading="lazy" sizes="(max-width: 767px) 100vw, (max-width: 991px) 728px, 940px" src={image.src} srcset={image.set} />
                </div>
              </div>
            ))}
          </div>
          <div class="testimonial-slider-nav w-slider-nav w-slider-nav-invert w-round"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="roof-product-section section-padding">
    <div class="w-layout-blockcontainer container w-container">
      <div class="section-content-wrapper">
        <div class="section-header style-03" style="opacity:1">
          <div class="title-wrapper style-02">
            <h2 class="section-title">Project Types</h2>
            <p class="section-subtitle">Use these categories when sending photos or requesting a quotation.</p>
          </div>
        </div>
        <div class="roof-products" style="opacity:1">
          {services.map((service) => (
            <div class="single-roof-products">
              <div class="roof-product-image-wrapper">
                <img alt={`${service.title} project category`} class="roof-product-image" loading="lazy" sizes="100vw" src={service.image} srcset={service.imageSet} />
                <p class="life-span">{service.number}</p>
              </div>
              <div class="roof-product-content">
                <div class="roof-product-title-wrapper">
                  <p class="roof-product-title">{service.title}</p>
                  <p class="roof-product-subtitle">{service.excerpt}</p>
                </div>
                <div class="roof-product-prices"><a class="button-style-04 w-button" href={service.href}>Details</a></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CTA title="Have a similar project?" text="Send photos of the roof, leak area, plumbing fault, wiring area, renovation space or drainage issue for a clearer first response." />
</BaseLayout>
