---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import HeroSimple from "../components/HeroSimple.astro";
import ServiceList from "../components/ServiceList.astro";
import { absorbedServices, services } from "../data/site";
---
<BaseLayout
  title="Services"
  description="Explore Boon Chye's consolidated services: roof leaking and waterproofing, plumbing and water pump, electrical, renovation, sewerage and drainage."
  path="/service"
>
  <HeroSimple label="our services" title="Consolidated Services" subtitle="Useful content from all nine source sites has been grouped into one practical service menu." />

  <section class="service-section section-padding">
    <div class="w-layout-blockcontainer container w-container">
      <div class="section-content-wrapper">
        <ServiceList />
      </div>
    </div>
  </section>

  <section class="roof-product-section section-padding">
    <div class="w-layout-blockcontainer container w-container">
      <div class="section-content-wrapper">
        <div class="section-header style-03" style="opacity:1">
          <div class="title-wrapper style-02">
            <h2 class="section-title">Service Coverage</h2>
            <p class="section-subtitle">Grouped by the work customers actually search for, not by the old microsite structure.</p>
          </div>
        </div>
        <div class="roof-products" style="opacity:1">
          {services.map((service) => (
            <div class="single-roof-products">
              <div class="roof-product-image-wrapper">
                <img alt={`${service.title} service image`} class="roof-product-image" loading="lazy" sizes="100vw" src={service.image} srcset={service.imageSet} />
                <p class="life-span">{service.number}</p>
              </div>
              <div class="roof-product-content">
                <div class="roof-product-title-wrapper">
                  <p class="roof-product-title">{service.title}</p>
                  <p class="roof-product-subtitle">{service.excerpt}</p>
                </div>
                <div class="roof-product-prices">
                  <a class="button-style-04 w-button" href={service.href}>Details</a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="why-choose-us section-padding">
    <div class="w-layout-blockcontainer container w-container">
      <div class="section-content-wrapper">
        <div class="title-wrapper style-02" style="opacity:1">
          <h2 class="section-title">All Absorbed Services</h2>
          <p class="section-subtitle">The top of the page shows 5 umbrella categories. These are the individual services consolidated from the 9 old websites.</p>
        </div>
        <div class="why-choose-card-wrapper" style="opacity:1">
          {absorbedServices.map((group) => (
            <div class="single-choose-us-card absorbed-service-card">
              <h4 class="choose-us-card-title">{group.category}</h4>
              <p class="choose-us-card-subtitle">{group.items.join(" / ")}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CTA title="Not sure which service you need?" text="Call or WhatsApp Boon Chye. The team can inspect the issue and route it to the right trade service." />
</BaseLayout>
