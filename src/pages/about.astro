---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import HeroSimple from "../components/HeroSimple.astro";
import { brand, sourceSites, trustPoints } from "../data/site";
---
<BaseLayout
  title="About"
  description="Learn about Boon Chye Renovation & Construction, consolidated from nine related source websites into one umbrella contractor brand."
  path="/about"
>
  <HeroSimple label="about us" title="About Boon Chye" subtitle="A unified website for the Boon Chye-related roof leaking, plumbing, electrical, renovation, waterproofing, sewerage and drainage services." />

  <section class="about-card-section padding-bottom">
    <div class="w-layout-blockcontainer container w-container">
      <div class="about-card-wrapper" style="opacity:1">
        <div class="single-about-coloumn">
          <div class="single-about-card">
            <h4 class="about-card-title">Our Commitment</h4>
            <p class="about-card-subtitle">Provide practical site inspection, clear quotation and workmanship-led repair or renovation support without confusing customers across separate microsites.</p>
          </div>
          <img alt="Roofing and waterproofing work" class="about-card-image" loading="lazy" sizes="(max-width: 767px) 100vw, (max-width: 991px) 728px, 820px" src="/images/prepearing-installation-photovoltaic-solar-panel-system-roof.png" srcset="/images/prepearing-installation-photovoltaic-solar-panel-system-roof-p-500.png 500w, /images/prepearing-installation-photovoltaic-solar-panel-system-roof-p-800.png 800w, /images/prepearing-installation-photovoltaic-solar-panel-system-roof.png 820w" />
        </div>
        <div class="single-about-coloumn _02">
          <img alt="Site technician at work" class="about-card-image" loading="lazy" sizes="(max-width: 767px) 100vw, (max-width: 991px) 728px, 820px" src="/images/man-working-roof-front-view.png" srcset="/images/man-working-roof-front-view-p-500.png 500w, /images/man-working-roof-front-view-p-800.png 800w, /images/man-working-roof-front-view.png 820w" />
          <div class="single-about-card">
            <h4 class="about-card-title">Who We Are</h4>
            <p class="about-card-subtitle">{brand.name} is presented here as the umbrella brand absorbing useful service content from nine related Boon Chye and specialist trade websites.</p>
          </div>
        </div>
        <div class="single-about-coloumn">
          <div class="single-about-card">
            <h4 class="about-card-title">Our Mission</h4>
            <p class="about-card-subtitle">Help property owners in KL and Selangor solve roof leaks, water damage, plumbing faults, electrical works, renovations and sewerage issues with one coordinated service path.</p>
          </div>
          <img alt="Renovation and construction team" class="about-card-image" loading="lazy" sizes="(max-width: 767px) 100vw, (max-width: 991px) 728px, 820px" src="/images/asian-male-site.png" srcset="/images/asian-male-site-p-500.png 500w, /images/asian-male-site-p-800.png 800w, /images/asian-male-site.png 820w" />
        </div>
      </div>
      <div class="about-cta" style="opacity:1">
        <h3 class="about-cta-title">One clear Boon Chye website, <span class="highlight-title">built from nine overlapping source sites.</span></h3>
        <a class="button-style-01 w-button" href="/service">View services</a>
      </div>
    </div>
  </section>

  <section class="why-choose-us section-padding">
    <div class="w-layout-blockcontainer container w-container">
      <div class="section-content-wrapper">
        <div class="title-wrapper style-02" style="opacity:1">
          <h2 class="section-title">What We Preserved</h2>
          <p class="section-subtitle">The strongest recurring trust and service signals from the source websites.</p>
        </div>
        <div class="why-choose-card-wrapper" style="opacity:1">
          {trustPoints.map((point) => (
            <div class="single-choose-us-card">
              <h4 class="choose-us-card-title">{point.title}</h4>
              <p class="choose-us-card-subtitle">{point.text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="service-section section-padding">
    <div class="w-layout-blockcontainer container w-container">
      <div class="section-content-wrapper">
        <div class="title-wrapper style-02" style="opacity:1">
          <h2 class="section-title">Source Websites Crawled</h2>
          <p class="section-subtitle">All nine sites were treated as references, then deduplicated into one content structure.</p>
        </div>
        <div class="why-choose-card-wrapper migration-source-grid" style="opacity:1">
          {sourceSites.map((site) => (
            <div class="single-choose-us-card">
              <h4 class="choose-us-card-title">Source</h4>
              <p class="choose-us-card-subtitle"><a href={site} target="_blank" rel="noopener">{site}</a></p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CTA title="Ready to discuss your property work?" text="Share your service type, location and photos for a clearer inspection or quotation." />
</BaseLayout>
