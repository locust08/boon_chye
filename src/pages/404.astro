---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout
  title="Page Not Found | Boon Chye"
  description="The requested Boon Chye page could not be found."
  path="/404"
>
  <section class="hero-section">
    <img alt="Sky background" class="sky-bg" loading="lazy" src="/images/Sky.svg" />
    <div class="w-layout-blockcontainer container-large padding w-container">
      <div class="w-layout-blockcontainer container w-container">
        <div class="hero-content-wrapper style-02" style="opacity:1">
          <h5 class="section-label">404</h5>
          <div class="title-wrapper align-center">
            <h1 class="hero-title">Page Not Found</h1>
            <p class="hero-subtitle style-03">The page may have moved during the Boon Chye website consolidation.</p>
          </div>
          <div class="hero-button-wrapper"><a class="button-style-01 w-button" href="/">Back to home</a><a class="button-style-02 w-button" href="/contact">Contact us</a></div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
