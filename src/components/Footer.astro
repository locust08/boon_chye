---
import { brand, footerContactDirectory, services } from "../data/site";
---
<section class="footer-section padding-bottom">
  <div class="w-layout-blockcontainer container w-container">
    <div class="footer-content-wrapper">
      <div class="footer-top-content">
        <div class="single-footer-link-wrapper">
          <p class="footer-link-title">About Us</p>
          <div class="footer-links-wrapper footer-about-wrapper">
            <p class="footer-about-text">Boon Chye provides reliable plumbing, waterproofing, renovation and sewerage solutions for homes and businesses across Malaysia.</p>
            <img alt={`${brand.shortName} logo`} class="footer-about-logo-image" loading="lazy" src={brand.logo} />
          </div>
        </div>
        <div class="single-footer-link-wrapper">
          <p class="footer-link-title">Our Services</p>
          <div class="footer-links-wrapper">
            {services.map((service) => <a class="footer-link" href={service.href}>{service.title}</a>)}
          </div>
        </div>
        <div class="single-footer-link-wrapper footer-contact-directory">
          <p class="footer-link-title">Contact Directory</p>
          <div class="footer-links-wrapper footer-directory-wrapper">
            <div class="footer-directory-card">
              {footerContactDirectory.map((contact) => (
              <div class="footer-contact-row">
                <span class="footer-contact-label">{contact.label}</span>
                <a class="footer-link footer-contact-number" href={contact.href} target={contact.href.startsWith("http") ? "_blank" : undefined} rel={contact.href.startsWith("http") ? "noopener" : undefined}>{contact.number}</a>
                <button class="footer-copy-button" type="button" data-copy={contact.number} aria-label={`Copy ${contact.number}`}>
                  <svg class="footer-copy-icon" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M8 8V5.5C8 4.1 9.1 3 10.5 3h8C19.9 3 21 4.1 21 5.5v8c0 1.4-1.1 2.5-2.5 2.5H16v2.5c0 1.4-1.1 2.5-2.5 2.5h-8C4.1 21 3 19.9 3 18.5v-8C3 9.1 4.1 8 5.5 8H8Zm2 0h3.5C14.9 8 16 9.1 16 10.5V14h2.5c.3 0 .5-.2.5-.5v-8c0-.3-.2-.5-.5-.5h-8c-.3 0-.5.2-.5.5V8Zm-4.5 2c-.3 0-.5.2-.5.5v8c0 .3.2.5.5.5h8c.3 0 .5-.2.5-.5v-8c0-.3-.2-.5-.5-.5h-8Z" fill="currentColor"/>
                  </svg>
                  <span class="footer-copy-label">Copied</span>
                </button>
              </div>
              ))}
            </div>
            <a class="footer-directory-link" href="/contact">View all service contacts</a>
          </div>
        </div>
        <div class="single-footer-link-wrapper footer-get-in-touch">
          <p class="footer-link-title">Get In Touch</p>
          <div class="footer-links-wrapper footer-touch-wrapper">
            <div class="footer-touch-row">
              <span class="footer-touch-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24"><path d="M12 21s7-5.3 7-12A7 7 0 1 0 5 9c0 6.7 7 12 7 12Zm0-9a3 3 0 1 1 0-6 3 3 0 0 1 0 6Z" fill="currentColor"/></svg>
              </span>
              <p class="footer-touch-text">{brand.address}</p>
            </div>
            <div class="footer-touch-row">
              <span class="footer-touch-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24"><path d="M3 6.5C3 5.1 4.1 4 5.5 4h13C19.9 4 21 5.1 21 6.5v11c0 1.4-1.1 2.5-2.5 2.5h-13C4.1 20 3 18.9 3 17.5v-11Zm2.7-.5 6.3 5 6.3-5H5.7Zm13.3 2.2-6.4 5.1a1 1 0 0 1-1.2 0L5 8.2v9.3c0 .3.2.5.5.5h13c.3 0 .5-.2.5-.5V8.2Z" fill="currentColor"/></svg>
              </span>
              <a class="footer-link footer-touch-link" href={`mailto:${brand.email}`}>{brand.email}</a>
            </div>
            <div class="footer-touch-row">
              <span class="footer-touch-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24"><path d="M12 22a10 10 0 1 1 0-20 10 10 0 0 1 0 20Zm1-10.4V7h-2v5.4l4.3 3.1 1.2-1.6-3.5-2.3Z" fill="currentColor"/></svg>
              </span>
              <p class="footer-touch-text">Mon - Sat: 8.30am - 6.00pm<br />Sun &amp; Public Holiday: Closed</p>
            </div>
          </div>
        </div>
      </div>
      <div class="footer-bottom-content">
        <p class="copyright-text">Copyright © 2026 {brand.name} ({brand.registration}). All Rights Reserved.</p>
      </div>
    </div>
  </div>
</section>
