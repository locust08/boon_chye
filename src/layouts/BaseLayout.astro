---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { brand } from "../data/site";

interface Props {
  title: string;
  description: string;
  path?: string;
}

const { title, description, path = Astro.url.pathname } = Astro.props;
const canonical = new URL(path, brand.canonicalBase).toString();
---
<html data-wf-page="6a13c437500bdc9bd5f69501" data-wf-site="6a13c435500bdc9bd5f694bc" lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta content={description} name="description" />
    <meta content="width=device-width, initial-scale=1" name="viewport" />
    <link href="/css/normalize.css" rel="stylesheet" type="text/css" />
    <link href="/css/webflow.css" rel="stylesheet" type="text/css" />
    <link href="/css/plumber-roofily.webflow.css" rel="stylesheet" type="text/css" />
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="anonymous" href="https://fonts.gstatic.com" rel="preconnect" />
    <script src="https://ajax.googleapis.com/ajax/libs/webfont/1.6.26/webfont.js" type="text/javascript"></script>
    <script type="text/javascript">WebFont.load({ google: { families: ["Bebas Neue:400","Geist:400,500,600,700,800,900"] } });</script>
    <script type="text/javascript">!function(o,c){var n=c.documentElement,t=" w-mod-";n.className+=t+"js",("ontouchstart"in o||o.DocumentTouch&&c instanceof DocumentTouch)&&(n.className+=t+"touch")}(window,document);</script>
    <link href="/images/boon-chye-logo-transparent.png" rel="shortcut icon" type="image/png" />
    <link href={canonical} rel="canonical" />
    <meta content={title} property="og:title" />
    <meta content={description} property="og:description" />
    <meta content={`${brand.canonicalBase}/images/boon-chye-logo-transparent.png`} property="og:image" />
    <meta content="website" property="og:type" />
    <meta content={canonical} property="og:url" />
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
    <script crossorigin="anonymous" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" src="https://d3e54v103j8qbb.cloudfront.net/js/jquery-3.5.1.min.dc5e7f18c8.js?site=6a13c435500bdc9bd5f694bc" type="text/javascript"></script>
    <script src="/js/webflow.js" type="text/javascript"></script>
    <script is:inline>
      (() => {
        const animatedSelectors = [
          ".section-header",
          ".title-wrapper",
          ".about-image",
          ".about-content",
          ".about-card-wrapper",
          ".about-cta",
          ".single-service",
          ".single-choose-us-card",
          ".project-gallery",
          ".metrics",
          ".how-it-works-content-wrapper",
          ".process-image-wrapper",
          ".roof-products",
          ".single-roof-products",
          ".testimonial-slider",
          ".faq-content-wrapper",
          ".cta-content-wrapper",
          ".contact-card-wrapper",
          ".contact-form-wrapper",
          ".service-details-content-wrapper",
          ".footer-content-wrapper"
        ];

        const elements = [...document.querySelectorAll(animatedSelectors.join(","))];
        if (!elements.length || window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

        document.documentElement.classList.add("bc-motion-ready");
        elements.forEach((element, index) => {
          element.classList.add("bc-animate");
          element.style.transitionDelay = `${Math.min(index % 6, 5) * 70}ms`;
        });

        if (!("IntersectionObserver" in window)) {
          elements.forEach((element) => element.classList.add("bc-visible"));
          return;
        }

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add("bc-visible");
            observer.unobserve(entry.target);
          });
        }, { rootMargin: "0px 0px -8% 0px", threshold: 0.12 });

        elements.forEach((element) => observer.observe(element));
      })();
    </script>
    <script is:inline>
      (() => {
        const sliders = document.querySelectorAll(".testimonial-slider");
        if (!sliders.length) return;

        sliders.forEach((slider) => {
          let startX = 0;
          let startY = 0;
          let tracking = false;
          let moved = false;
          let dragSource = "";
          let startScroll = 0;

          const syncDots = () => {
            const dots = [...slider.querySelectorAll(".w-slider-dot")];
            const slide = slider.querySelector(".w-slide");
            if (!dots.length || !slide) return;
            const slideWidth = slide.getBoundingClientRect().width || 1;
            const activeIndex = Math.max(0, Math.min(dots.length - 1, Math.round(slider.scrollLeft / slideWidth)));
            dots.forEach((dot, index) => dot.classList.toggle("w-active", index === activeIndex));
          };

          const snapToNearestSlide = () => {
            const slide = slider.querySelector(".w-slide");
            if (!slide) return;
            const slideWidth = slide.getBoundingClientRect().width || 1;
            const target = Math.round(slider.scrollLeft / slideWidth) * slideWidth;
            if (typeof slider.scrollTo === "function") {
              slider.scrollTo({ left: target, behavior: "smooth" });
            } else {
              slider.scrollLeft = target;
            }
            window.setTimeout(syncDots, 250);
          };

          const pointFromEvent = (event) => {
            const touch = event.changedTouches && event.changedTouches[0];
            return touch || event;
          };

          const startDrag = (event, source) => {
            if (event.button !== undefined && event.button !== 0) return;
            const point = pointFromEvent(event);
            tracking = true;
            moved = false;
            dragSource = source;
            startX = point.clientX;
            startY = point.clientY;
            startScroll = slider.scrollLeft;
            slider.classList.add("is-dragging");
          };

          const updateDrag = (event) => {
            if (!tracking) return;
            const point = pointFromEvent(event);
            const deltaX = point.clientX - startX;
            const deltaY = point.clientY - startY;
            if (Math.abs(deltaX) > 8 && Math.abs(deltaX) > Math.abs(deltaY)) {
              moved = true;
              if (event.cancelable) event.preventDefault();
              slider.scrollLeft = startScroll - deltaX;
              syncDots();
            }
          };

          const finishDrag = (event) => {
            if (!tracking) return;
            const point = pointFromEvent(event);
            tracking = false;
            dragSource = "";
            slider.classList.remove("is-dragging");
            const deltaX = point.clientX - startX;
            const deltaY = point.clientY - startY;
            if (!moved || Math.abs(deltaX) < 50 || Math.abs(deltaX) < Math.abs(deltaY)) return;
            snapToNearestSlide();
          };

          slider.addEventListener("dragstart", (event) => event.preventDefault());
          slider.addEventListener("pointerdown", (event) => startDrag(event, "pointer"), true);
          slider.addEventListener("pointermove", updateDrag, true);
          slider.addEventListener("pointerup", finishDrag, true);
          slider.addEventListener("mousedown", (event) => startDrag(event, "mouse"), true);
          window.addEventListener("mousemove", (event) => {
            if (dragSource === "mouse") updateDrag(event);
          }, true);
          window.addEventListener("mouseup", (event) => {
            if (dragSource === "mouse") finishDrag(event);
          }, true);
          slider.addEventListener("touchstart", (event) => startDrag(event, "touch"), { capture: true, passive: true });
          slider.addEventListener("touchmove", (event) => {
            if (dragSource === "touch") updateDrag(event);
          }, { capture: true, passive: false });
          slider.addEventListener("touchend", (event) => {
            if (dragSource === "touch") finishDrag(event);
          }, true);
          slider.addEventListener("pointercancel", () => {
            tracking = false;
            dragSource = "";
            slider.classList.remove("is-dragging");
          });
          slider.addEventListener("lostpointercapture", () => {
            tracking = false;
            dragSource = "";
            slider.classList.remove("is-dragging");
          });
        });
      })();
    </script>
    <script is:inline>
      (() => {
        const buttons = document.querySelectorAll("[data-copy]");
        if (!buttons.length) return;

        const fallbackCopy = (value) => {
          const input = document.createElement("textarea");
          input.value = value;
          input.setAttribute("readonly", "");
          input.style.position = "absolute";
          input.style.left = "-9999px";
          document.body.appendChild(input);
          input.select();
          document.execCommand("copy");
          input.remove();
        };

        buttons.forEach((button) => {
          button.addEventListener("click", async () => {
            const value = button.getAttribute("data-copy");
            if (!value) return;
            try {
              if (navigator.clipboard && window.isSecureContext) {
                await navigator.clipboard.writeText(value);
              } else {
                fallbackCopy(value);
              }
              button.classList.add("is-copied");
              window.setTimeout(() => button.classList.remove("is-copied"), 900);
            } catch {
              fallbackCopy(value);
            }
          });
        });
      })();
    </script>
    <script is:inline>
      (() => {
        const getFaqs = () => [...document.querySelectorAll(".single-faq")];

        const setOpen = (faq, open) => {
          const question = faq.querySelector(".question");
          const answer = faq.querySelector(".answer");
          faq.classList.toggle("w--open", open);
          question?.classList.toggle("w--open", open);
          answer?.classList.toggle("w--open", open);
          question?.setAttribute("aria-expanded", String(open));
        };

        const initFaqs = () => {
          getFaqs().forEach((faq) => {
            const question = faq.querySelector(".question");
            if (!question) return;
            question.setAttribute("role", "button");
            question.setAttribute("tabindex", "0");
            question.setAttribute("aria-expanded", faq.classList.contains("w--open") ? "true" : "false");
          });
        };

        const toggleFaq = (question) => {
          const faq = question.closest(".single-faq");
          if (!faq) return;
          const shouldOpen = !faq.classList.contains("w--open");
          getFaqs().forEach((item) => setOpen(item, false));
          setOpen(faq, shouldOpen);
        };

        document.addEventListener("click", (event) => {
          const question = event.target.closest(".single-faq .question");
          if (!question) return;
          event.preventDefault();
          event.stopPropagation();
          toggleFaq(question);
        }, true);

        document.addEventListener("keydown", (event) => {
          if (event.key !== "Enter" && event.key !== " ") return;
          const question = event.target.closest(".single-faq .question");
          if (!question) return;
          event.preventDefault();
          event.stopPropagation();
          toggleFaq(question);
        }, true);

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", initFaqs);
        } else {
          initFaqs();
        }
      })();
    </script>
  </body>
</html>
